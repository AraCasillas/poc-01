<%# Le damos un título específico a esta página %>
<% @title = "Future Industries — Login" %>

<div class="login-container">
  <div class="login-box">

    <div class="login-header">
      <h1>Welcome to Future Industries</h1>
      <p class="subtitle">Where we build the future</p>
    </div>

    <%# Si @error tiene valor, mostramos el mensaje de error %>
    <% if @error %>
      <div class="alert-error">
        <p><%= @error %></p>
      </div>
    <% end %>

    <%# El formulario envía los datos a POST /login %>
    <form action="/login" method="post">

      <div class="form-group">
        <label for="email">E-mail address</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="Enter your email"
          required>
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          placeholder="Your password"
          required>
      </div>

      <button type="submit" class="btn-primary">
        Login
      </button>

    </form>

    <%# Hint de usuarios de prueba — solo para el PoC %>
    <div class="hint">
      <p><strong>Test Credentials</strong></p>
      <p>avatarKyoshi@futureIndustries.com / rangiIsTheBestGirlfriend</p>
      <p>avatarKorra@futureIndustries.com / iloveAsamiSato&lt;3</p>
    </div>

  </div>
</div>